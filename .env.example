# Copia este fichero a .env y rellena los valores.

# --- Acceso ---
# Contraseña para entrar en la app. Vacío = sin login.
APP_PASSWORD=

# --- Proveedor de IA ---
# Elige uno: "openai" o "gemini". Si lo dejas vacío, se autodetecta según qué
# clave esté presente (Gemini si sólo hay GOOGLE_API_KEY, OpenAI si sólo hay
# OPENAI_API_KEY, OpenAI por defecto si hay ambas).
AI_PROVIDER=gemini

# OpenAI: Whisper (transcripción) + GPT-4o-mini (corrección). De pago.
# Saca tu clave en https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Gemini: gemini-2.5-flash maneja audio + texto. Tiene tier gratuito generoso.
# Saca tu clave en https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# --- Almacenamiento ---
# "local" (filesystem) o "s3" (Cloudflare R2 / S3)
STORAGE_BACKEND=local

# Sólo si STORAGE_BACKEND=s3
S3_BUCKET=dedicatorias-prod
S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=auto

# Opcional: ruta a los datos en modo local (por defecto ./data)
# LOCAL_STORAGE_ROOT=/ruta/a/datos
