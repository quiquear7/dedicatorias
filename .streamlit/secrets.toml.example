# Plantilla para Streamlit Community Cloud.
# Copia este contenido en "Advanced settings → Secrets" del despliegue.
# Para desarrollo local usa el archivo .env de la raíz en su lugar.

OPENAI_API_KEY = "sk-..."

STORAGE_BACKEND = "s3"
S3_BUCKET = "dedicatorias-prod"
S3_ENDPOINT = "https://<accountid>.r2.cloudflarestorage.com"
S3_ACCESS_KEY = "..."
S3_SECRET_KEY = "..."
S3_REGION = "auto"
